#!name = 彩云天气去广告
#!desc = 移除首页推广、弹窗、悬浮窗、底栏天气助手和工具箱入口，移除我的页面广告横幅。
#!openUrl = 
#!author = @jiaweiding
#!homepage = https://github.com/jiaweiding/scripts
#!icon = https://raw.githubusercontent.com/Orz-3/mini/master/Color/caiyun.png
#!system = iOS,iPadOS,macOS,watchOS
#!date = 2025-09-03 14:30:00
#!version = 1.0.0

[URL Rewrite]
# > 通用广告请求@ddgksf2013
^https?:\/\/ad\.cyapi\.cn\/v\d reject-200

[Script]
# > 伪装VIP解锁48小时降水[需登录][新验证接口][需旧版≤ 7.20.2]@ddgksf2013
http-response ^https?:\/\/biz\.cyapi\.cn\/api\/v\d\/user_detail script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=伪装VIP解锁用户详情
# > 伪装VIP解锁48小时降水[需登录][需旧版≤ 7.20.2]@ddgksf2013
http-response ^https?:\/\/biz\.cyapi\.cn\/v\d\/user script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=伪装VIP解锁用户信息
# > 图层推广@ddgksf2013
http-response ^https?:\/\/wrapper\.cyapi\.cn\/v\d\/activity script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除图层推广
# > 活动推广@ddgksf2013
http-response ^https?:\/\/api\.caiyunapp\.com\/v\d\/activity script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除活动推广
# > 首页顶部推广@ddgksf2013
http-response ^https?:\/\/starplucker\.cyapi\.cn\/v\d/operation/homefeatures script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除首页顶部推广
# > SVIP提醒推广@ddgksf2013
http-response ^https?:\/\/starplucker\.cyapi\.cn\/v\d/notification/message_center script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除SVIP提醒推广
# > 雨季特惠提醒@ddgksf2013
http-response ^https?:\/\/starplucker\.cyapi\.cn\/v\d/config/cypage script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除雨季特惠提醒
# > 发现页信息流推荐@ddgksf2013
http-response ^https?:\/\/starplucker\.cyapi\.cn\/v\d/operation/feeds script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除发现页信息流推荐
# > 发现页banners@ddgksf2013
http-response ^https?:\/\/starplucker\.cyapi\.cn\/v\d/operation/banners script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除发现页banners
# > 发现页中间部分@ddgksf2013
http-response ^https?:\/\/starplucker\.cyapi\.cn\/v\d/operation/features script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除发现页中间部分
# > 发现页活动@ddgksf2013
http-response ^https?:\/\/starplucker\.cyapi\.cn\/v\d/campaigns script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/refs/heads/master/caiyun_json.js, requires-body=true, timeout=20, tag=移除发现页活动

[MITM]
hostname = wrapper.cyapi.cn, api.caiyunapp.com, starplucker.cyapi.cn, ad.cyapi.cn, biz.cyapi.cn